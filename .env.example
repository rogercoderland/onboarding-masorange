# Copia este archivo a `.env.local` y rellena los valores (no commitees `.env.local`).
# Contentful → Settings → API keys (Space ID + tokens de Delivery/Preview).

# ID del space de Contentful
CONTENTFUL_SPACE_ID=
# Environment del space (normalmente "master")
CONTENTFUL_ENVIRONMENT=master

# Content Delivery API token (contenido publicado · runtime)
CONTENT_DELIVERY_API_KEY=
# Content Preview API token (borradores · opcional)
CONTENT_PREVIEW_API_KEY=

# Personal Access Token / CMA (CFPAT-...) · solo para tooling build-time
CMA_TOKEN=

# Secreto que autentica /api/revalidate (cabecera x-revalidate-secret).
# Úsalo como secreto del webhook de Contentful (revalidación al publicar).
REVALIDATE_SECRET=

# ConfigCat
NEXT_PUBLIC_CONFIGCAT_SDK_KEY=
CONFIGCAT_SDK_KEY=
